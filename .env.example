# Deben ser diferentes entre sí y difíciles de adivinar.
VITE_ADMIN_PASSWORD=change-this-admin-password
VITE_COCINA_PASSWORD=change-this-cocina-password
VITE_OPERADOR_PASSWORD=change-this-operador-password
